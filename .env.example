# PostgreSQL
POSTGRES_USER=vandepot
POSTGRES_PASSWORD=vandepot
POSTGRES_DB=vandepot
POSTGRES_HOST=localhost
POSTGRES_PORT=5438

# Redis
REDIS_HOST=localhost
REDIS_PORT=6381

# Backend
BACKEND_PORT=3100
RUST_LOG=debug

# Database connection string — superuser, used ONLY for migrations + seed at
# boot. NOT used for runtime traffic (Postgres superusers bypass RLS regardless
# of FORCE ROW LEVEL SECURITY).
DATABASE_URL=postgresql://vandepot:vandepot@localhost:5438/vandepot

# Runtime app DB connection — non-superuser role `vandepot_app` so RLS
# `FORCE ROW LEVEL SECURITY` actually binds at the SQL layer. Provisioned by
# migration 20260509000002_create_app_role.sql. The API binary fails to boot
# if this is unset (no silent fallback to DATABASE_URL).
DATABASE_URL_APP=postgresql://vandepot_app:vandepot_app@localhost:5438/vandepot

# Redis connection string
REDIS_URL=redis://localhost:6381

# JWT
JWT_SECRET=vandepot-dev-secret-change-in-prod
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# Superadmin seed
# Set RUN_SEED_SUPERADMIN=true to upsert a superadmin user at boot.
# When enabled, BOTH SUPERADMIN_EMAIL and SUPERADMIN_PASSWORD are REQUIRED.
# SUPERADMIN_PASSWORD must be >=16 chars and contain at least one
# uppercase letter, one lowercase letter, and one digit.
# The process exits non-zero if any rule fails — there is NO fallback.
RUN_SEED_SUPERADMIN=false
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=<set-via-secrets-manager>

# Default tenant seed (DEV ONLY)
# Set RUN_SEED_DEFAULT_TENANT=true to upsert the default tenant at boot.
# Slug is hardcoded to `dev` (the user-locked `default` is reserved by
# migration 20260507000001's CHECK constraint). Name is `Default Tenant`.
# `make reset-db` sets this to true automatically — leave it false otherwise.
RUN_SEED_DEFAULT_TENANT=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3100
FRONTEND_PORT=3201
